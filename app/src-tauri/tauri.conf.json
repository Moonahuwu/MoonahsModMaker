{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deadlock Intro Music Tool",
  "version": "0.1.0",
  "identifier": "com.digiphoenix.deadlock-intro-tool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Deadlock Intro Music Tool",
        "width": 1180,
        "height": 860,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../tools/vpk-helper/dist/vpk-helper.exe": "vpk-helper.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
